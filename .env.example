# 🤖 FC Mobile Info Bot - Variables de entorno
# Copia este archivo como .env y completa con tus valores

# 🔑 Token del bot de Telegram (obtener de @BotFather)
# Requerido para que el bot funcione
TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# 👥 ID del grupo para notificaciones de inicio/parada del bot
# Opcional - deja vacío si no quieres notificaciones en grupo
GROUP_ID=

# 👤 Tu ID de Telegram para recibir notificaciones de errores
# Opcional - el bot te avisará cuando ocurra un error
OWNER_ID=
